# Safe local essentials only. Production operators should review the canonical
# installed reference at trading/deploy/aws/sfo-weather.env.example.
SFO_FORECASTER_ROOT=/absolute/path/to/WeatherEdge/forecaster
SFO_KALSHI_DB=/absolute/path/to/WeatherEdge/trading/data/paper_trading.db

# Google Weather server-side refresh.
GOOGLE_WEATHER_API_KEY=replace_with_google_weather_key
GOOGLE_WEATHER_MONTHLY_EVENT_BUDGET=8000
GOOGLE_WEATHER_DAILY_EVENT_BUDGET=260
ENABLE_GOOGLE_DAILY_FORECAST=1
ENABLE_GOOGLE_CURRENT_CONDITIONS=1

# Paper trading. There is no live real-money order placement path.
# Paper trading has no daily spend cap; exposure is risk-gated per position,
# per target date, and one entry per market/side.
PAPER_BANKROLL=1000
PAPER_RISK_PROFILE=live
PAPER_TAKE_PROFIT_PCT=35
PAPER_STOP_LOSS_PCT=35

# Optional venue API access. Paper research works without these values.
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=
# CAUTION: prod selects the production API host even though WeatherEdge does not
# place real orders. Prefer demo for credentialed local experiments.
KALSHI_ENV=prod
