# Safe local essentials only. Production operators should review
# deploy/aws/sfo-weather.env.example. Paper trading works without venue credentials.
SFO_FORECASTER_ROOT=/absolute/path/to/WeatherEdge/forecaster
SFO_KALSHI_DB=/absolute/path/to/WeatherEdge/trading/data/paper_trading.db
# No daily spend cap: exposure is risk-gated per position, per target date,
# and one entry per market/side.
PAPER_BANKROLL=1000
PAPER_RISK_PROFILE=live

# Optional venue API access. Paper research works without these values.
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=
# Local credentialed experiments use the demo API host.
KALSHI_ENV=demo
