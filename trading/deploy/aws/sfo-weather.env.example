GOOGLE_WEATHER_API_KEY=replace_with_google_weather_key
GOOGLE_WEATHER_MONTHLY_EVENT_BUDGET=8000
GOOGLE_WEATHER_DAILY_EVENT_BUDGET=260

# Production reads the production prediction-market data API. Real-order
# execution remains independently gated off by SFO_LIVE_TRADING_ENABLED below.
KALSHI_ENV=prod

# The EC2 timer is the always-on forecast owner; there is no separate enable gate.
# Freshness watchdog: fail if weather.db is older than this many hours (default 6,
# ahead of the 12 h live trade-halt). The systemd failure handler optionally
# posts one JSON alert to the configured webhook.
SFO_FORECAST_MAX_AGE_HOURS=6
SFO_FRESHNESS_ALERT_URL=
SFO_BASE_DIR=/opt/weatheredge
SFO_DISK_USAGE_MAX_PERCENT=85
ENABLE_GOOGLE_DAILY_FORECAST=1
ENABLE_GOOGLE_CURRENT_CONDITIONS=1
GOOGLE_DAILY_INTERNAL_WEIGHT=0.15
SFO_PUBLISH_PAGES=1
SFO_FORECASTER_GIT_REMOTE=git@github.com:Jaxsonb04/weather_edge.git
SFO_FORECASTER_GIT_BRANCH=main
SFO_FORECASTER_SOURCE_SUBDIR=forecaster
SFO_PAGES_BRANCH=gh-pages
SFO_PAGES_DEPLOY_KEY=/home/ubuntu/.ssh/sfo_weather_pages_deploy
SFO_PAGES_GIT_AUTHOR_NAME=JaxsonB04
SFO_PAGES_GIT_AUTHOR_EMAIL=JaxsonB04@users.noreply.github.com
SFO_FORECASTER_SOURCE_CACHE=/opt/weatheredge/.cache/main
SFO_FORECASTER_SOURCE_LOCK=/opt/weatheredge/.locks/source-cache-main.lock
SFO_ARTIFACT_GENERATION_LOCK=/opt/weatheredge/.locks/artifact-generation.lock
SFO_ARTIFACT_LOCK_WAIT_SECONDS=900
SFO_WEBDIST_DIR=/opt/weatheredge/webdist
SFO_PAGES_LOCK=/opt/weatheredge/.locks/pages-publish.lock
SFO_PAGES_PUSH_ATTEMPTS=4

SFO_FORECASTER_ROOT=/opt/weatheredge/forecaster
SFO_TRADING_ROOT=/opt/weatheredge/trading
SFO_TRADING_PYTHON=/opt/weatheredge/trading/.venv/bin/python
SFO_FORECAST_DB=/opt/weatheredge/forecaster/weather.db
SFO_FORECAST_STALE_MARKER=/opt/weatheredge/forecaster/STALE_FORECAST
SFO_PUBLICATION_MANIFEST_PATH=/opt/weatheredge/forecaster/publication_manifest.json
SFO_PUBLICATION_MAX_OPERATIONAL_AGE_MINUTES=15
SFO_PUBLICATION_MAX_PUBLIC_OPERATIONAL_AGE_MINUTES=20
SFO_PUBLICATION_MAX_STRATEGY_AGE_MINUTES=20
# Verify the manifest that visitors receive when Pages publishing is enabled.
SFO_PUBLICATION_MANIFEST_URL=https://jaxsonb04.github.io/weather_edge/publication_manifest.json
SFO_KALSHI_DB=/opt/weatheredge/trading/data/paper_trading.db
SFO_DATASET_DB=/opt/weatheredge/trading/data/paper_trading.db
# Runtime-produced nightly research summary consumed by Strategy Lab.
SFO_DATASET_RESEARCH_PATH=/opt/weatheredge/forecaster/dataset_research.json
# Keep NOAA ISD out of the first scheduled pass while NCEI access is unstable.
# Add noaa-isd here after the source is healthy from the EC2 runtime.
SFO_DATASET_SOURCES=iem-asos,open-meteo-previous-runs,open-meteo-historical-forecast,lamp,gfs-mos,nbm,hrrr,kalshi-history
SFO_DATASET_LOOKBACK_DAYS=10
SFO_DATASET_KALSHI_LOOKBACK_DAYS=90
SFO_DATASET_KALSHI_CANDLES=0
SFO_DATASET_KALSHI_TRADES=0
SFO_DATASET_KALSHI_MAX_TRADE_PAGES=1
# Retry only the CLI's dedicated temporary-lock exit; network/data failures
# still fail immediately and remain visible to the systemd failure alert.
# Attempts must be 1-10; delay must be 0-300 seconds (up to milliseconds).
SFO_DATASET_LOCK_RETRY_ATTEMPTS=3
SFO_DATASET_LOCK_RETRY_DELAY_SECONDS=5
SFO_TRADING_SIGNAL_TARGET_DATE=both
SFO_TRADING_SIGNAL_SIDE=both
SFO_TRADING_SIGNAL_CALIBRATION_SOURCE=lstm
SFO_TRADING_SIGNAL_DISABLE_ENSEMBLE=0
SFO_STRATEGY_RESEARCH_CALIBRATION_MIN_TRAIN=180
# Paper trading has no daily spend cap. Exposure is risk-gated instead:
# per-position risk, a per-target exposure cap, and one entry per market/side.
PAPER_BANKROLL=1000
# Two profiles only: `live` is the stricter real-money-INTENT record (paper-only
# until the readiness gate passes); `research` is the loose, tiny-size data
# collector. Leave the headline report profile on `live`.
PAPER_RISK_PROFILE=live
# The scanner runs both profile books in the same DB. Leave PAPER_RISK_PROFILE=live
# so reports default to the real-money candidate record, while PAPER_RISK_PROFILES
# lets the scheduled paper scanner collect both. `research` is the tiny-size
# collector with its own book; it gathers the widest opportunity set (center bins
# included) that the readiness rescore needs.
PAPER_RISK_PROFILES=live,research
# market fills approved entries immediately at the visible ask (more paper
# fills, more frequently). limit instead records buy-limit orders at the
# lower-confidence reservation price; those rest and only fill when the ask
# trades down to the limit, so many approvals expire unfilled. Default to
# market (2026-06-17) so approvals become trades instead of resting orders.
# Maker-first execution (2026-07-06): post resting limit orders instead of
# crossing the spread. Resting quotes pay the maker fee (25% of taker); fills
# are simulated when the visible ask crosses the limit -- a stated proxy, not
# exchange truth. Set back to `market` to compare taker execution.
PAPER_ENTRY_MODE=limit
# Independent, explicit paper-placement controls. All three are safe-off when
# missing, malformed, or set to an unrecognized value. Research controls can
# never enable the live candidate; enable each account deliberately after its
# deployment checks pass.
PAPER_PLACE_LIVE=0
PAPER_PLACE_RESEARCH_TARGET=0
PAPER_PLACE_RESEARCH_MOTION=0

# Which city markets to scan/settle: 'all' (default) or comma slugs, e.g.
# sfo,nyc,mia. The registry lives in cities.py.
PAPER_CITIES=all
# Serialize scheduled profile scans; this matches the runner's default lock.
SFO_PAPER_SCAN_LOCK=/opt/weatheredge/.locks/paper-scan.lock
PAPER_ROLLING_TARGETS=3
# Fixed-standard local hour after which same-day entry scanning rolls forward.
PAPER_SAME_DAY_ENTRY_CUTOFF_HOUR=14
# Keep official CLI settlement refresh enabled. Set to 1 only for diagnosis.
SFO_DISABLE_CLISFO=0
# The scheduled scanner places through the shared portfolio allocator:
# guaranteed arbitrage first, high-confidence NO core next, capped YES convex
# sleeve, then research exploration when the profile allows it.
SFO_PORTFOLIO_MAX_ARB_SPEND=12
SFO_PORTFOLIO_MIN_PROFIT=0.01
PAPER_TAKE_PROFIT_PCT=40
PAPER_STOP_LOSS_PCT=35
PAPER_YES_TAKE_PROFIT_PCT=50
PAPER_YES_STOP_LOSS_PCT=25
PAPER_NO_TAKE_PROFIT_PCT=35
PAPER_NO_STOP_LOSS_PCT=35
PAPER_MODEL_VETO_MAX_LOSS_PCT=60
PAPER_MODEL_VETO_BUFFER=0.08
# Safe-off rollout gate. When enabled, paper-monitor writes fresh model
# probability snapshots for already-open same-day positions after the 14:00
# fixed-standard entry cutoff. It never reopens scanning or places new entries.
PAPER_SAME_DAY_MODEL_HEARTBEAT_ENABLED=false

# Live-execution boundary: all five gates are documented and safe-off. The
# paper engine does not place real orders; do not enable these without a
# separately reviewed live-order module and operator approval.
SFO_LIVE_TRADING_ENABLED=0
SFO_LIVE_TRADING_DRY_RUN=1
SFO_LIVE_PILOT_MAX_LOSS=50
SFO_LIVE_DAILY_LOSS=20
SFO_LIVE_PER_TRADE_RISK=10

# Archive-gated retention. S3 upload is disabled while the bucket is blank.
SFO_ARCHIVE_DIR=/opt/weatheredge/trading/data/archive
SFO_ARCHIVE_KEEP_DAYS=30
SFO_ARCHIVE_S3_BUCKET=
SFO_ARCHIVE_S3_PREFIX=paper_trading
SFO_ARCHIVE_AWS_CLI=aws
SFO_DATABASE_BACKUP_S3_PREFIX=database-snapshots
SFO_DATABASE_BACKUP_DIR=/opt/weatheredge/trading/data/backups
SFO_DATABASE_BACKUP_KEEP_DAYS=7
# Set to 1 only while provisioning a deliberately empty replacement host.
SFO_ALLOW_EMPTY_DATABASE_DEPLOY=0
SFO_FK_AUDIT_LIMIT=100
# Keep only the most recent UTC day at full decision-snapshot resolution;
# the dedicated archive-gated prune service retains older sampled evidence.
SFO_PRUNE_FULL_DAYS=1
SFO_PRUNE_DEDUP_DAYS=45
