GOOGLE_WEATHER_API_KEY=replace_with_google_weather_key
GOOGLE_WEATHER_MONTHLY_EVENT_BUDGET=8000
GOOGLE_WEATHER_DAILY_EVENT_BUDGET=260
ENABLE_GOOGLE_DAILY_FORECAST=1
ENABLE_GOOGLE_CURRENT_CONDITIONS=1
GOOGLE_DAILY_INTERNAL_WEIGHT=0.15
SFO_PUBLISH_PAGES=1
SFO_FORECASTER_GIT_REMOTE=git@github.com:Jaxsonb04/weather-edge.git
SFO_FORECASTER_GIT_BRANCH=main
SFO_FORECASTER_SOURCE_SUBDIR=forecaster
SFO_PAGES_BRANCH=gh-pages
SFO_PAGES_DEPLOY_KEY=/home/ubuntu/.ssh/sfo_weather_pages_deploy
SFO_PAGES_GIT_AUTHOR_NAME=JaxsonB04
SFO_PAGES_GIT_AUTHOR_EMAIL=JaxsonB04@users.noreply.github.com
SFO_FORECASTER_SOURCE_CACHE=/opt/weatheredge/.cache/main
# Temporary public Strategy Lab mode: publish plaintext strategy_research.json.
# Restore the password gate by setting SFO_STRATEGY_LAB_PUBLIC_MODE=0 and
# SFO_STRATEGY_LAB_PASSWORD to a private value.
SFO_STRATEGY_LAB_PUBLIC_MODE=1
# Restorable password mode. Ignored while SFO_STRATEGY_LAB_PUBLIC_MODE=1.
# SFO_STRATEGY_LAB_PASSWORD=replace_with_private_strategy_lab_password
SFO_STRATEGY_LAB_PBKDF2_ITERATIONS=210000

SFO_FORECASTER_ROOT=/opt/weatheredge/forecaster
SFO_KALSHI_DB=/opt/weatheredge/trading/data/paper_trading.db
SFO_DATASET_DB=/opt/weatheredge/trading/data/paper_trading.db
# Keep NOAA ISD out of the first scheduled pass while NCEI access is unstable.
# Add noaa-isd here after the source is healthy from Lightsail.
SFO_DATASET_SOURCES=iem-asos,open-meteo-previous-runs,open-meteo-historical-forecast,kalshi-history
SFO_DATASET_LOOKBACK_DAYS=10
SFO_DATASET_KALSHI_LOOKBACK_DAYS=90
SFO_DATASET_KALSHI_CANDLES=0
SFO_DATASET_KALSHI_TRADES=0
SFO_DATASET_KALSHI_MAX_TRADE_PAGES=1
SFO_TRADING_SIGNAL_TARGET_DATE=both
SFO_TRADING_SIGNAL_SIDE=both
SFO_TRADING_SIGNAL_CALIBRATION_SOURCE=lstm
SFO_TRADING_SIGNAL_DISABLE_ENSEMBLE=0
SFO_STRATEGY_RESEARCH_CALIBRATION_MIN_TRAIN=180
# Paper trading has no daily spend cap. Exposure is risk-gated instead:
# per-position risk, a per-target exposure cap, and one entry per market/side.
PAPER_BANKROLL=1000
# Use balanced for the stricter paper-research record. Use fast-feedback when
# you want the paper journal to collect small entries faster.
PAPER_RISK_PROFILE=balanced
# The scanner can run multiple profile books in the same DB. Leave
# PAPER_RISK_PROFILE=balanced so reports default to the serious record, while
# PAPER_RISK_PROFILES lets the scheduled paper scanner collect all of them.
# exploratory is a second tiny-size collector with its own book, added
# (2026-06-17) to raise paper-trade throughput on the same opportunity set.
PAPER_RISK_PROFILES=balanced,fast-feedback,exploratory
# Optional fixed spend per approved scan entry. Profile max-contract caps still
# apply, so fast-feedback remains small even with this set.
# PAPER_SCAN_STAKE=5
# market fills approved entries immediately at the visible ask (more paper
# fills, more frequently). limit instead records buy-limit orders at the
# lower-confidence reservation price; those rest and only fill when the ask
# trades down to the limit, so many approvals expire unfilled. Default to
# market (2026-06-17) so approvals become trades instead of resting orders.
PAPER_ENTRY_MODE=market
# The scheduled scanner runs the forecast-centered tail basket before the broad
# analyzer. It buys paper NO on far edge buckets and a smaller center YES only
# when all basket guardrails pass.
SFO_PAPER_SCAN_TAIL_BASKET_ENABLED=1
SFO_TAIL_BASKET_DISTANCE=3
SFO_TAIL_BASKET_TAIL_STAKE=5
SFO_TAIL_BASKET_CENTER_STAKE=1
SFO_TAIL_BASKET_MAX_TAIL_PROBABILITY=0.20
SFO_TAIL_BASKET_MAX_SPEND=12
SFO_TAIL_BASKET_MAX_WORST_LOSS=8
PAPER_TAKE_PROFIT_PCT=40
PAPER_STOP_LOSS_PCT=35
PAPER_YES_TAKE_PROFIT_PCT=50
PAPER_YES_STOP_LOSS_PCT=25
PAPER_NO_TAKE_PROFIT_PCT=35
PAPER_NO_STOP_LOSS_PCT=35
PAPER_MODEL_VETO_MAX_LOSS_PCT=60
PAPER_MODEL_VETO_BUFFER=0.08
