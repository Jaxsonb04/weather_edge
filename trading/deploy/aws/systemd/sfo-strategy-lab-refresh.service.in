[Unit]
Description=SFO Strategy Lab trading-results refresh
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
User=__APP_USER__
WorkingDirectory=__FORECASTER_DIR__
EnvironmentFile=__ENV_FILE__
ExecStart=/bin/bash __TRADING_DIR__/deploy/aws/sync_forecaster_source.sh
ExecStart=/bin/bash __TRADING_DIR__/deploy/aws/run_publication_cycle.sh strategy
Nice=5
# Contain a runaway strategy-research build to this unit instead of letting
# the kernel OOM-killer pick an arbitrary victim (4 GB box: containment, not
# thrash-protection). A healthy cycle peaks well under the cap now that
# decision-snapshot sampling runs in SQL instead of materializing rows.
MemoryHigh=1200M
MemoryMax=1600M
# Fail a stuck cycle fast instead of blocking the shared publication queue for
# hours (memory-throttled strategy-research once ran 76 minutes).
TimeoutStartSec=900
